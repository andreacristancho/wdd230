@media screen and (min-width: 600px) {
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;

    gap: 20px;
  }

  .first-card {
    margin: 200px 0;
    grid-template-columns: 1/2;
  }

  .second-card {
    margin: 200px 0;
    grid-template-columns: 2/3;
  }

  .third-card {
    margin: 200px 0;
    grid-template-columns: 3/4;
  }
}
